{
  "name": "project-hub",
  "version": "0.5.1",
  "description": "Project hub for Bitbucket-based .NET projects",
  "author": "Anton",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ./scripts/run-electron-vite.cjs dev",
    "build": "node ./scripts/run-electron-vite.cjs build",
    "build:win": "node ./scripts/run-electron-vite.cjs build && electron-builder --win",
    "release": "node ./scripts/run-electron-vite.cjs build && electron-builder --win --publish always",
    "preview": "node ./scripts/run-electron-vite.cjs preview",
    "start": "node ./scripts/run-electron-vite.cjs preview"
  },
  "build": {
    "appId": "com.antonl.workhelper",
    "productName": "WorkHelper",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorkHelper",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "lukianovanton",
      "repo": "workhelper",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "mysql2": "^3.22.2",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^2.5.4",
    "tree-kill": "^1.2.2",
    "tw-animate-css": "^1.2.0",
    "zustand": "^5.0.1"
  }
}
